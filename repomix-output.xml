    const {
        acadYearOpts,
        allSemStrs,
        existingOpts,
        facultyid,
        semestralRecord,
        opts,
        dependencyMaps,
        previousUrl,
    }: Props = $props();

    // Check for changes
    const haveChanges: boolean[] = $state(Array(5).fill(false));
    const hasChange = $derived(haveChanges.some((e) => e === true));

