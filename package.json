{
    "name": "fims",
    "private": true,
    "version": "0.0.1",
    "type": "module",
    "engines": {
        "node": ">=24.13.0 <25.0.0"
    },
    "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
    "scripts": {
        "dev": "vite dev",
        "build": "vite build",
        "preview": "vite preview",
        "prepare": "svelte-kit sync || echo ''",
        "es:fix": "eslint --cache --fix .",
        "fix": "pnpm fmt:fix && pnpm es:fix",
        "fmt": "prettier --experimental-cli --cache-location .prettiercache --check .",
        "fmt:fix": "prettier --experimental-cli --cache-location .prettiercache --write .",
        "lint": "pnpm --workspace-root --parallel /^lint:/",
        "lint:es": "eslint --cache .",
        "lint:sv": "svelte-check --tsconfig ./tsconfig.json",
        "test": "pnpm test:unit && pnpm test:e2e",
        "test:e2e": "playwright test || echo ''",
        "test:unit": "vitest run || echo ''",
        "auth:schema": "npx @better-auth/cli generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:studio": "drizzle-kit studio",
        "db:seed": "vite-node --options.transformMode.ssr='/.*/' src/lib/server/db/seed-db.ts",
        "docker:dev": "docker-compose --file compose.yaml --file compose.dev.yaml up --detach --wait",
        "docker:down": "docker-compose down --remove-orphans"
    },
    "devDependencies": {
        "@bastidood/eslint-plugin-imsort": "^0.11.0",
        "@eslint/css": "0.14.1",
        "@eslint/js": "^9.39.4",
        "@html-eslint/eslint-plugin": "^0.54.2",
        "@html-eslint/eslint-plugin-svelte": "^0.60.0",
        "@neondatabase/serverless": "^1.1.0",
        "@playwright/test": "^1.59.1",
        "@sveltejs/adapter-node": "^5.5.4",
        "@sveltejs/kit": "^2.59.0",
        "@sveltejs/vite-plugin-svelte": "^6.2.4",
        "@tailwindcss/forms": "^0.5.11",
        "@tailwindcss/vite": "^4.2.4",
        "@types/node": "^25.6.0",
        "@types/pg": "^8.20.0",
        "@vitest/browser-playwright": "^4.1.5",
        "dotenv": "^17.4.2",
        "drizzle-kit": "^0.31.10",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-svelte": "^3.17.1",
        "globals": "^17.6.0",
        "playwright": "^1.59.1",
        "prettier": "^3.8.3",
        "prettier-plugin-svelte": "^3.5.1",
        "prettier-plugin-tailwindcss": "^0.7.4",
        "svelte-check": "^4.4.7",
        "svelte-eslint-parser": "^1.6.0",
        "tailwind-csstree": "^0.1.5",
        "tailwindcss": "^4.2.4",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.59.2",
        "vite": "^7.3.2",
        "vite-node": "^6.0.0",
        "vitest": "^4.1.5",
        "vitest-browser-svelte": "^2.1.1"
    },
    "dependencies": {
        "@iconify/svelte": "^5.2.1",
        "@protobi/exceljs": "4.4.0-protobi.9",
        "better-auth": "^1.6.9",
        "drizzle-orm": "^0.45.2",
        "pg": "^8.20.0",
        "svelte": "5.49.1",
        "valibot": "^1.3.1"
    }
}
